---
import { references } from '../data/references';

// Sort references alphabetically by author, then by year
const sortedReferences = [...references].sort((a, b) => {
	const authorA = a.author.toLowerCase();
	const authorB = b.author.toLowerCase();
	if (authorA !== authorB) {
		return authorA.localeCompare(authorB);
	}
	return a.year - b.year;
});
---

<section id="references" class="mx-auto max-w-2xl px-6 py-24">
	<h2 class="text-2xl font-bold text-black">References</h2>
	<ol class="mt-3 list-decimal space-y-4 pl-6 text-base leading-relaxed text-black">
		{sortedReferences.map((ref) => (
			<li id={`reference-${ref.id}`} class="reference-item">
				<div class="reference-entry mb-1">
					<strong>{ref.author}</strong> ({ref.year}). <em>{ref.title}</em>. Retrieved from <a
						href={ref.url}
						target="_blank"
						rel="noopener noreferrer"
						class="text-[#780000] underline hover:text-[#c1121f]"
					>
						{ref.url}
					</a>
				</div>
			</li>
		))}
	</ol>
</section>

<style>
	/* APA format styling */
	ol {
		list-style: none;
		counter-reset: item;
		padding-left: 0;
	}

	li {
		counter-increment: item;
		margin-bottom: 1rem;
	}

	.reference-entry {
		--hanging-indent: 2rem;
		padding: 0.85rem 1.1rem 0.85rem calc(1.1rem + var(--hanging-indent));
		text-indent: calc(-1 * var(--hanging-indent));
		border-radius: 0.375rem;
		background-color: transparent;
	}

	em {
		font-style: italic;
	}

	.reference-item:target .reference-entry {
		animation: reference-highlight-fade 4s ease-out forwards;
	}

	.reference-item:target {
		scroll-margin-top: 5.5rem;
	}

	@keyframes reference-highlight-fade {
		0% {
			background-color: #fef08a;
		}
		65% {
			background-color: #fef9c3;
		}
		100% {
			background-color: transparent;
		}
	}
</style>
